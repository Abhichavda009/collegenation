{{ 'college-nation-home.css' | asset_url | stylesheet_tag }}

{%- assign bs_collection = section.settings.collection -%}

<section class="cn-home cn-featured-products cn-bestsellers" data-cn-carousel style="--cn-padding-top: {{ section.settings.padding_top }}px; --cn-padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="cn-home-container">
    <div class="cn-trending-head">
      <h2 class="cn-home-section-title">{{ section.settings.heading }}</h2>
      {%- if section.settings.link_label != blank -%}
        <a class="cn-trending-all" href="{{ section.settings.link | default: routes.all_products_collection_url }}">{{ section.settings.link_label }}</a>
      {%- endif -%}
    </div>
    <div class="cn-product-track" data-cn-carousel-track>
      {%- if bs_collection != blank and bs_collection.products_count > 0 -%}
        {%- for product in bs_collection.products limit: section.settings.product_limit -%}
          <article class="cn-product-card">
            <a class="cn-card-media" href="{{ product.url }}">
              {%- if section.settings.show_rank and forloop.index <= 3 -%}
                <span class="cn-bestseller-rank">#{{ forloop.index }}</span>
              {%- endif -%}
              {%- unless product.available -%}
                <span class="cn-card-badge cn-card-badge-sold">Sold Out</span>
              {%- else -%}
                {%- if product.compare_at_price > product.price -%}
                  <span class="cn-card-badge">Sale</span>
                {%- endif -%}
              {%- endunless -%}
              {%- if product.featured_image -%}
                {{ product.featured_image | image_url: width: 640 | image_tag: loading: 'lazy', sizes: '268px', widths: '320, 480, 640', alt: product.title }}
              {%- endif -%}
              <span class="cn-card-choose">Choose Options</span>
            </a>
            <div class="cn-card-body">
              <span class="cn-card-vendor">{{ product.vendor }}</span>
              <a href="{{ product.url }}" class="cn-card-title">{{ product.title }}</a>
              {%- if section.settings.show_rating -%}
                {%- liquid
                  assign rating_value = section.settings.default_rating
                  assign rating_count = 0
                  if product.metafields.reviews.rating.value != blank
                    assign rating_value = product.metafields.reviews.rating.value.rating
                    assign rating_count = product.metafields.reviews.rating_count.value
                  endif
                  assign rating_round = rating_value | round
                -%}
                <div class="cn-card-rating" aria-label="{{ rating_value }} out of 5 stars">
                  {%- for i in (1..5) -%}
                    <span class="cn-card-star{% if i <= rating_round %} is-on{% endif %}" aria-hidden="true">★</span>
                  {%- endfor -%}
                  {%- if rating_count > 0 -%}
                    <span class="cn-card-reviews">({{ rating_count }})</span>
                  {%- endif -%}
                </div>
              {%- endif -%}
              <div class="cn-card-price">
                <span>{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="cn-card-compare">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              </div>
            </div>
          </article>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..5) -%}
          <article class="cn-product-card">
            <div class="cn-card-media"></div>
            <div class="cn-card-body">
              <span class="cn-card-vendor">College Nation</span>
              <span class="cn-card-title">Add products to the selected collection</span>
              <div class="cn-card-price"><span>{{ 4500 | money }}</span></div>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
    <div class="cn-carousel-footer">
      <div class="cn-carousel-progress"><span class="cn-carousel-progress-bar" data-cn-carousel-bar></span></div>
      <div class="cn-carousel-nav">
        <button class="cn-carousel-arrow" type="button" aria-label="Previous products" data-cn-carousel-prev>&#8249;</button>
        <button class="cn-carousel-arrow" type="button" aria-label="Next products" data-cn-carousel-next>&#8250;</button>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'college-nation-home.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "CN best sellers",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best Sellers This Week" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "label": "Products", "min": 4, "max": 16, "step": 1, "default": 10 },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View All" },
    { "type": "url", "id": "link", "label": "Link" },
    { "type": "checkbox", "id": "show_rank", "label": "Show #1-#3 rank badges", "default": true },
    { "type": "checkbox", "id": "show_rating", "label": "Show star ratings", "default": true },
    { "type": "range", "id": "default_rating", "label": "Default rating (used until a reviews app provides real ratings)", "min": 0, "max": 5, "step": 1, "default": 5 },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 8 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 72 }
  ],
  "presets": [{ "name": "CN best sellers" }]
}
{% endschema %}
