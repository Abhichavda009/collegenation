{{ 'college-nation-home.css' | asset_url | stylesheet_tag }}

{%- assign featured_collection = section.settings.collection -%}

<section class="cn-home cn-featured-products" data-cn-carousel style="--cn-padding-top: {{ section.settings.padding_top }}px; --cn-padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="cn-home-container">
    <h2 class="cn-home-section-title">{{ section.settings.heading }}</h2>
    <div class="cn-product-track" data-cn-carousel-track>
      {%- if section.settings.show_promo_card -%}
        <a class="cn-carousel-promo" href="{{ section.settings.promo_link | default: routes.all_products_collection_url }}">
          <span class="cn-carousel-script">{{ section.settings.promo_script }}</span>
          <span class="cn-carousel-promo-title">{{ section.settings.promo_title | newline_to_br }}</span>
        </a>
      {%- endif -%}
      {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
        {%- for product in featured_collection.products limit: section.settings.product_limit -%}
          <article class="cn-product-card">
            <a class="cn-card-media" href="{{ product.url }}">
              {%- unless product.available -%}<span class="cn-card-badge">Sold Out</span>{%- endunless -%}
              {%- if product.featured_image -%}
                {{ product.featured_image | image_url: width: 640 | image_tag: loading: 'lazy', sizes: '268px', widths: '320, 480, 640', alt: product.title }}
              {%- endif -%}
              <span class="cn-card-choose">Choose Options</span>
            </a>
            <div class="cn-card-body">
              <span class="cn-card-vendor">{{ product.vendor }}</span>
              <a href="{{ product.url }}" class="cn-card-title">{{ product.title }}</a>
              <div class="cn-card-price">
                <span>{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="cn-card-compare">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              </div>
              <span class="cn-card-swatch"></span>
            </div>
          </article>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <article class="cn-product-card">
            <div class="cn-card-media"></div>
            <div class="cn-card-body">
              <span class="cn-card-vendor">College Nation</span>
              <span class="cn-card-title">Add products to the selected collection</span>
              <div class="cn-card-price"><span>{{ 4500 | money }}</span></div>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
    <div class="cn-carousel-footer">
      <div class="cn-carousel-progress"><span class="cn-carousel-progress-bar" data-cn-carousel-bar></span></div>
      <div class="cn-carousel-nav">
        <button class="cn-carousel-arrow" type="button" aria-label="Previous products" data-cn-carousel-prev>&#8249;</button>
        <button class="cn-carousel-arrow" type="button" aria-label="Next products" data-cn-carousel-next>&#8250;</button>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'college-nation-home.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "CN featured products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Collections" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "label": "Products", "min": 4, "max": 16, "step": 1, "default": 10 },
    { "type": "checkbox", "id": "show_promo_card", "label": "Show promo card", "default": true },
    { "type": "text", "id": "promo_script", "label": "Promo script text", "default": "Shop" },
    { "type": "textarea", "id": "promo_title", "label": "Promo title", "default": "NEW\nARRIVALS" },
    { "type": "url", "id": "promo_link", "label": "Promo link" },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 }
  ],
  "presets": [{ "name": "CN featured products" }]
}
{% endschema %}
