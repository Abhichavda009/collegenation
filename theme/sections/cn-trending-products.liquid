{{ 'college-nation-home.css' | asset_url | stylesheet_tag }}

{%- assign trending_collection = section.settings.collection -%}

<section class="cn-home cn-trending" style="--cn-padding-top: {{ section.settings.padding_top }}px; --cn-padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="cn-home-container">
    <div class="cn-trending-head">
      <h2 class="cn-home-section-title">{{ section.settings.heading }}</h2>
      <a class="cn-trending-all" href="{{ section.settings.link | default: routes.all_products_collection_url }}">{{ section.settings.link_label }}</a>
    </div>
    <div class="cn-trending-grid">
      {%- if trending_collection != blank and trending_collection.products_count > 0 -%}
        {%- for product in trending_collection.products limit: section.settings.product_limit -%}
          <a class="cn-trending-card" href="{{ product.url }}">
            {%- if product.featured_image -%}
              {{ product.featured_image | image_url: width: 160 | image_tag: class: 'cn-trending-thumb', loading: 'lazy', sizes: '56px', widths: '112, 160', alt: product.title }}
            {%- endif -%}
            <span class="cn-trending-info">
              <span class="cn-trending-vendor">{{ product.vendor }}</span>
              <span class="cn-trending-name">{{ product.title }}</span>
              <span class="cn-trending-price">{{ product.price | money }}</span>
            </span>
            <span class="cn-trending-arrow" aria-hidden="true">&#8250;</span>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..6) -%}
          <div class="cn-trending-card">
            <span class="cn-trending-thumb"></span>
            <span class="cn-trending-info">
              <span class="cn-trending-vendor">College Nation</span>
              <span class="cn-trending-name">Select a collection to show products</span>
              <span class="cn-trending-price">{{ 4500 | money }}</span>
            </span>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CN trending products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trending This Week" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "label": "Products", "min": 3, "max": 12, "step": 1, "default": 6 },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop All Products" },
    { "type": "url", "id": "link", "label": "Link" },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 8 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 80 }
  ],
  "presets": [{ "name": "CN trending products" }]
}
{% endschema %}
