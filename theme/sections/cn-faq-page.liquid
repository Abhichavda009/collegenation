{{ 'college-nation-pages.css' | asset_url | stylesheet_tag }}

<section class="cn-page" data-cn-faq>
  <div class="cn-page-container" style="--cn-page-padding-top: {{ section.settings.padding_top }}px; --cn-page-padding-bottom: {{ section.settings.padding_bottom }}px;">
    {%- if section.settings.show_breadcrumbs -%}
      {%- render 'cn-breadcrumb', title: section.settings.heading -%}
    {%- endif -%}

    <div class="cn-faq-content">
      <h1 class="cn-page-title">{{ section.settings.heading }}</h1>
      <p class="cn-faq-lead-title">{{ section.settings.lead_title }}</p>
      <div class="cn-faq-lead-text">{{ section.settings.lead_text }}</div>

      {%- assign current_group = '' -%}
      {%- for block in section.blocks -%}
        <div class="cn-faq-section">
          {%- if block.settings.group != current_group -%}
            <h2 class="cn-faq-section-title">{{ block.settings.group }}</h2>
            {%- assign current_group = block.settings.group -%}
          {%- endif -%}
          <div class="cn-faq-item{% if block.settings.open_by_default %} is-open{% endif %}" data-cn-faq-item {{ block.shopify_attributes }}>
            <button class="cn-faq-question" type="button" aria-expanded="{% if block.settings.open_by_default %}true{% else %}false{% endif %}" data-cn-faq-question>
              <span>{{ block.settings.question }}</span>
              <span class="cn-faq-icon" data-cn-faq-icon aria-hidden="true">{% if block.settings.open_by_default %}-{% else %}+{% endif %}</span>
            </button>
            <div class="cn-faq-answer">{{ block.settings.answer }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script src="{{ 'college-nation-pages.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "CN FAQ page",
  "settings": [
    { "type": "checkbox", "id": "show_breadcrumbs", "label": "Show breadcrumbs", "default": true },
    { "type": "text", "id": "heading", "label": "Heading", "default": "FAQ" },
    { "type": "text", "id": "lead_title", "label": "Lead title", "default": "Your Ultimate College Gear Destination" },
    { "type": "richtext", "id": "lead_text", "label": "Lead text", "default": "<p>Welcome to College Nation, your one-stop shop for officially licensed college apparel and merchandise.</p>" },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "group", "label": "Group", "default": "Ordering & Accounts" },
        { "type": "text", "id": "question", "label": "Question", "default": "Do I need an account to place an order?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>No, you're welcome to check out as a guest. Creating an account lets you track orders and check out faster next time.</p>" },
        { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "CN FAQ page",
      "blocks": [
        { "type": "faq_item", "settings": { "group": "Ordering & Accounts", "question": "Do I need an account to place an order?", "answer": "<p>No, you're welcome to check out as a guest. Creating an account lets you track orders, save your details, and check out faster next time.</p>" } },
        { "type": "faq_item", "settings": { "group": "Ordering & Accounts", "question": "How do I place an order?", "answer": "<p>Browse or search for your school's gear, pick your size and color, add the items to your bag, and proceed to checkout.</p>" } },
        { "type": "faq_item", "settings": { "group": "Shipping & Delivery", "question": "How long does shipping take?", "answer": "<p>Orders typically ship within 1-2 business days and arrive within 3-7 business days, depending on your location.</p>" } },
        { "type": "faq_item", "settings": { "group": "Shipping & Delivery", "question": "Do you offer free shipping?", "answer": "<p>Yes. Enjoy free standard shipping on all orders over $45.</p>" } },
        { "type": "faq_item", "settings": { "group": "Returns & Exchanges", "question": "What is your return policy?", "answer": "<p>We accept returns of unworn, unwashed items with their original tags within 30 days of delivery.</p>" } },
        { "type": "faq_item", "settings": { "group": "Products & Sizing", "question": "Are your products officially licensed?", "answer": "<p>Yes, all College Nation apparel and merchandise is officially licensed by the universities and brands we carry.</p>" } }
      ]
    }
  ]
}
{% endschema %}
