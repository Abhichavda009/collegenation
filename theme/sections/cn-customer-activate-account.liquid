{{ 'college-nation-customer.css' | asset_url | stylesheet_tag }}

<section class="cn-customer">
  <div class="cn-customer__shell">
    <a class="cn-customer__logo" href="{{ routes.root_url }}">COLLEGE NATION</a>

    <div class="cn-customer__card">
      <h1>{{ section.settings.heading }}</h1>
      <p class="cn-customer__sub">{{ section.settings.subheading }}</p>

      {%- form 'activate_customer_password', class: 'cn-customer__form' -%}
        {%- if form.errors -%}
          <div class="cn-customer__errors">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        <label class="cn-customer__field">
          <span>Password</span>
          <input type="password" name="customer[password]" autocomplete="new-password" required>
        </label>
        <label class="cn-customer__field">
          <span>Confirm password</span>
          <input type="password" name="customer[password_confirmation]" autocomplete="new-password" required>
        </label>

        <button class="cn-customer__button" type="submit">{{ section.settings.activate_label }}</button>
        <button class="cn-customer__button cn-customer__button--secondary" type="submit" name="decline">{{ section.settings.decline_label }}</button>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Activate Account",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Activate account" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Create a password to activate your College Nation account." },
    { "type": "text", "id": "activate_label", "label": "Activate button label", "default": "Activate account" },
    { "type": "text", "id": "decline_label", "label": "Decline button label", "default": "Decline invitation" }
  ]
}
{% endschema %}
