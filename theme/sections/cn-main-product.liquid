{{ 'college-nation-commerce.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign stock_qty = current_variant.inventory_quantity | at_least: 0
  assign stock_pct = stock_qty | at_most: 10 | times: 10
  if stock_pct < 10 and current_variant.available
    assign stock_pct = 10
  endif
-%}

<script type="application/ld+json">
  {{ product | structured_data }}
</script>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": {{ shop.url | append: routes.root_url | json }}
      }
      {%- if collection -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ collection.title | json }},
          "item": {{ shop.url | append: collection.url | json }}
        }
      {%- endif -%}
      ,{
        "@type": "ListItem",
        "position": {%- if collection -%}3{%- else -%}2{%- endif -%},
        "name": {{ product.title | json }},
        "item": {{ shop.url | append: product.url | json }}
      }
    ]
  }
</script>

<section class="cn-commerce" data-cn-product>
  <div class="cn-product-inner">
    <nav class="cn-commerce-crumbs" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      {%- if collection -%}
        <span class="cn-commerce-sep" aria-hidden="true">|</span>
        <a href="{{ collection.url }}">Collection: {{ collection.title }}</a>
      {%- endif -%}
      <span class="cn-commerce-sep" aria-hidden="true">|</span>
      <span class="cn-commerce-crumb-active">{{ product.title }}</span>
    </nav>

    <div class="cn-product-body">
      <div class="cn-product-gallery">
        <div class="cn-product-media">
          {%- if product.featured_media -%}
            {%- assign main_image = product.featured_media.preview_image -%}
            <img
              src="{{ main_image | image_url: width: 1200 }}"
              srcset="{{ main_image | image_url: width: 600 }} 600w, {{ main_image | image_url: width: 900 }} 900w, {{ main_image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 860px) 100vw, 50vw"
              alt="{{ product.title | escape }}"
              width="{{ main_image.width }}"
              height="{{ main_image.height }}"
              loading="eager"
              fetchpriority="high"
              data-cn-main-image
            >
          {%- endif -%}
        </div>
        {%- if product.media.size > 1 -%}
          <div class="cn-product-thumbs">
            {%- for media in product.media -%}
              {%- if media.preview_image -%}
                {%- assign thumb_src = media.preview_image | image_url: width: 1200 -%}
                {%- capture thumb_srcset -%}
                  {{ media.preview_image | image_url: width: 600 }} 600w, {{ media.preview_image | image_url: width: 900 }} 900w, {{ media.preview_image | image_url: width: 1200 }} 1200w
                {%- endcapture -%}
                <button
                  class="cn-product-thumb{% if forloop.first %} is-active{% endif %}"
                  type="button"
                  data-cn-thumb
                  data-cn-image-src="{{ thumb_src }}"
                  data-cn-image-srcset="{{ thumb_srcset | strip }}"
                  aria-label="View image {{ forloop.index }}"
                >
                  {{ media.preview_image | image_url: width: 160 | image_tag: loading: 'lazy', sizes: '72px', widths: '100, 160', alt: product.title }}
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="cn-product-info">
        <h1 class="cn-product-title">{{ product.title }}</h1>
        <div class="cn-product-meta">
          {%- if product.vendor != blank -%}
            <span>Vendor: <a href="{{ routes.search_url }}?q={{ product.vendor | url_encode }}">{{ product.vendor }}</a></span>
          {%- endif -%}
          {%- if current_variant.sku != blank -%}
            <span class="cn-commerce-sep" aria-hidden="true">|</span>
            <span>SKU: <span data-cn-sku>{{ current_variant.sku }}</span></span>
          {%- endif -%}
        </div>

        <div class="cn-product-price" data-cn-product-price>{{ current_variant.price | money }}</div>

        {%- if current_variant.available -%}
          <p class="cn-product-stock">Hurry up, only <strong>{{ stock_qty }}</strong> items left in stock.</p>
          <div class="cn-product-bar"><span style="width: {{ stock_pct }}%;"></span></div>
        {%- else -%}
          <p class="cn-product-stock is-out">Out of stock</p>
        {%- endif -%}

        {%- if section.settings.show_delivery -%}
          {%- assign cn_now = 'now' | date: '%s' | times: 1 -%}
          {%- assign cn_min = section.settings.delivery_min_days | times: 86400 | plus: cn_now -%}
          {%- assign cn_max = section.settings.delivery_max_days | times: 86400 | plus: cn_now -%}
          <p class="cn-product-delivery">
            <span class="cn-product-delivery-icon" aria-hidden="true">&#128666;</span>
            {{ section.settings.delivery_prefix }}
            <strong>{{ cn_min | date: '%b %-d' }} &ndash; {{ cn_max | date: '%b %-d' }}</strong>
          </p>
        {%- endif -%}

        {%- form 'product', product, class: 'cn-product-form' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-cn-variant-select>

          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div class="cn-product-option">
                <span class="cn-product-option-label">
                  {{ option.name }}:
                  <span>{{ option.selected_value }}</span>
                </span>
                <div class="cn-product-values">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="cn-product-value{% if option.selected_value == value %} is-active{% endif %}"
                      data-cn-option-position="{{ option.position }}"
                      data-cn-option-value="{{ value | escape }}"
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endunless -%}

          <div class="cn-product-actions">
            <div class="cn-product-qty">
              <button type="button" aria-label="Decrease quantity" data-cn-qty-minus>-</button>
              <input type="number" name="quantity" min="1" value="1" data-cn-quantity aria-label="Quantity">
              <button type="button" aria-label="Increase quantity" data-cn-qty-plus>+</button>
            </div>
            <button
              type="submit"
              class="cn-product-add"
              data-cn-add-button
              data-available-text="{{ section.settings.add_to_cart_label }}"
              data-sold-out-text="{{ section.settings.sold_out_label }}"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              {%- if current_variant.available -%}{{ section.settings.add_to_cart_label }}{%- else -%}{{ section.settings.sold_out_label }}{%- endif -%}
            </button>
          </div>

          {%- if section.settings.show_dynamic_checkout -%}
            <div class="cn-product-dynamic">{{ form | payment_button }}</div>
          {%- endif -%}
        {%- endform -%}

        {%- assign assurance_blocks = section.blocks | where: 'type', 'assurance' -%}
        {%- if assurance_blocks.size > 0 -%}
          <ul class="cn-product-assurance">
            {%- for block in assurance_blocks -%}
              <li class="cn-product-assurance-item" {{ block.shopify_attributes }}>
                <span class="cn-product-assurance-icon" aria-hidden="true">{{ block.settings.icon }}</span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.show_payment -%}
          <div class="cn-product-payment">
            <span class="cn-product-payment-heading">{{ section.settings.payment_heading }}</span>
            <div class="cn-product-pay-methods">
              {%- assign pay_methods = section.settings.payment_methods | split: ',' -%}
              {%- for method in pay_methods -%}
                {%- assign method_clean = method | strip -%}
                {%- if method_clean != blank -%}
                  <span class="cn-product-pay-chip">{%- render 'cn-payment-icon', method: method_clean -%}</span>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        <div class="cn-product-description">
          {{ product.description }}
          {%- if product.metafields.custom.specifications != blank -%}
            <h2>{{ section.settings.specifications_heading }}</h2>
            {{ product.metafields.custom.specifications | metafield_tag }}
          {%- endif -%}
        </div>

        {%- if section.settings.show_specs -%}
          {%- assign spec_labels = 'Color,Size,Fabric,Age group,Neckline,Sleeve length,Target gender,Top length,Sleeve style,Stretch level,Decoration,Care instructions,Clothing features' | split: ',' -%}
          {%- assign spec_keys = 'color-pattern,size,fabric,age-group,neckline,sleeve-length-type,target-gender,top-length-type,sleeve-style,stretch-level,decoration-technique,care-instructions,clothing-features' | split: ',' -%}
          {%- assign spec_has = false -%}
          {%- for key in spec_keys -%}
            {%- if product.metafields.shopify[key] != blank -%}
              {%- assign spec_has = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if spec_has -%}
            <div class="cn-product-specs">
              <h2 class="cn-product-specs-title">{{ section.settings.specs_heading }}</h2>
              <dl class="cn-spec-list">
                {%- for key in spec_keys -%}
                  {%- assign spec_mf = product.metafields.shopify[key] -%}
                  {%- if spec_mf != blank -%}
                    <div class="cn-spec-row">
                      <dt class="cn-spec-label">{{ spec_labels[forloop.index0] }}</dt>
                      <dd class="cn-spec-value">
                        {%- assign spec_type = spec_mf.type -%}
                        {%- if spec_type contains 'list.metaobject' -%}
                          {%- for v in spec_mf.value -%}<span class="cn-spec-chip">{{ v.label }}</span>{%- endfor -%}
                        {%- elsif spec_type contains 'metaobject' -%}
                          <span class="cn-spec-chip">{{ spec_mf.value.label }}</span>
                        {%- elsif spec_type contains 'list.' -%}
                          {%- for v in spec_mf.value -%}<span class="cn-spec-chip">{{ v }}</span>{%- endfor -%}
                        {%- else -%}
                          <span class="cn-spec-chip">{{ spec_mf.value }}</span>
                        {%- endif -%}
                      </dd>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </dl>
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- assign accordion_blocks = section.blocks | where: 'type', 'accordion' -%}
        {%- if accordion_blocks.size > 0 -%}
          <div class="cn-product-accordions">
            {%- for block in accordion_blocks -%}
              <details class="cn-product-accordion"{% if block.settings.open_by_default %} open{% endif %} {{ block.shopify_attributes }}>
                <summary class="cn-product-accordion-summary">
                  {{ block.settings.title }}
                  <span class="cn-product-accordion-icon" aria-hidden="true">+</span>
                </summary>
                <div class="cn-product-accordion-body">{{ block.settings.content }}</div>
              </details>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <div class="cn-product-extra">
          <a href="#share">Share</a>
          <a href="{{ section.settings.shipping_link | default: '#' }}">{{ section.settings.shipping_label }}</a>
        </div>
      </div>
    </div>
  </div>

  <script type="application/json" data-cn-variants-json>
    [
      {%- for variant in product.variants -%}
        {
          "id": {{ variant.id | json }},
          "available": {{ variant.available | json }},
          "options": {{ variant.options | json }},
          "priceFormatted": {{ variant.price | money | json }},
          "sku": {{ variant.sku | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  </script>
</section>

<script src="{{ 'college-nation-commerce.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "CN main product",
  "settings": [
    { "type": "text", "id": "add_to_cart_label", "label": "Add to cart label", "default": "Add To Cart" },
    { "type": "text", "id": "sold_out_label", "label": "Sold out label", "default": "Sold Out" },
    { "type": "checkbox", "id": "show_dynamic_checkout", "label": "Show dynamic checkout", "default": true },
    { "type": "header", "content": "Delivery estimate" },
    { "type": "checkbox", "id": "show_delivery", "label": "Show delivery estimate", "default": true },
    { "type": "text", "id": "delivery_prefix", "label": "Delivery prefix", "default": "Estimated delivery:" },
    { "type": "range", "id": "delivery_min_days", "label": "Min days", "min": 1, "max": 21, "step": 1, "default": 3 },
    { "type": "range", "id": "delivery_max_days", "label": "Max days", "min": 1, "max": 30, "step": 1, "default": 7 },
    { "type": "header", "content": "Payment reassurance" },
    { "type": "checkbox", "id": "show_payment", "label": "Show payment row", "default": true },
    { "type": "text", "id": "payment_heading", "label": "Payment heading", "default": "Guaranteed Safe Checkout" },
    { "type": "text", "id": "payment_methods", "label": "Payment methods (comma separated)", "default": "Visa, Mastercard, UPI, PayPal, Amex, RuPay" },
    { "type": "header", "content": "Description & links" },
    { "type": "text", "id": "shipping_label", "label": "Shipping link label", "default": "Shipping Details" },
    { "type": "url", "id": "shipping_link", "label": "Shipping link" },
    { "type": "text", "id": "specifications_heading", "label": "Specifications heading", "default": "Specifications" },
    { "type": "header", "content": "Product details (category metafields)" },
    { "type": "checkbox", "id": "show_specs", "label": "Show category attribute details", "default": true },
    { "type": "text", "id": "specs_heading", "label": "Product details heading", "default": "Product Details" }
  ],
  "blocks": [
    {
      "type": "assurance",
      "name": "Assurance badge",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🚚" },
        { "type": "text", "id": "text", "label": "Text", "default": "Free shipping over ₹45" }
      ]
    },
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Shipping & Returns" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Add your details here.</p>" },
        { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false }
      ]
    }
  ],
  "presets": [{ "name": "CN main product" }]
}
{% endschema %}
