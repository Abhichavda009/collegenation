{{ 'college-nation-home.css' | asset_url | stylesheet_tag }}

<section class="cn-home cn-brands" style="--cn-padding-top: {{ section.settings.padding_top }}px; --cn-padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="cn-home-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="cn-brands-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="cn-brands-row">
      {%- for block in section.blocks -%}
        {%- if block.settings.link != blank -%}
          <a class="cn-brands-item" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 320 | image_tag: loading: 'lazy', sizes: '160px', widths: '160, 320', alt: block.settings.name }}
            {%- else -%}
              <span class="cn-brands-name">{{ block.settings.name }}</span>
            {%- endif -%}
          </a>
        {%- else -%}
          <span class="cn-brands-item" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 320 | image_tag: loading: 'lazy', sizes: '160px', widths: '160, 320', alt: block.settings.name }}
            {%- else -%}
              <span class="cn-brands-name">{{ block.settings.name }}</span>
            {%- endif -%}
          </span>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CN brand logos",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Officially Licensed Brands" },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 8 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        { "type": "text", "id": "name", "label": "Brand name", "default": "Nike" },
        { "type": "image_picker", "id": "image", "label": "Logo image (optional)" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "CN brand logos",
      "blocks": [
        { "type": "brand", "settings": { "name": "Nike" } },
        { "type": "brand", "settings": { "name": "Champion" } },
        { "type": "brand", "settings": { "name": "Pro Standard" } },
        { "type": "brand", "settings": { "name": "Johnnie-O" } },
        { "type": "brand", "settings": { "name": "'47 Brand" } },
        { "type": "brand", "settings": { "name": "Colosseum" } }
      ]
    }
  ]
}
{% endschema %}
