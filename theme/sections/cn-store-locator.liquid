{{ 'college-nation-pages.css' | asset_url | stylesheet_tag }}

<section class="cn-page">
  <div class="cn-page-container" style="--cn-page-padding-top: {{ section.settings.padding_top }}px; --cn-page-padding-bottom: {{ section.settings.padding_bottom }}px;">
    {%- if section.settings.show_breadcrumbs -%}
      {%- render 'cn-breadcrumb', title: section.settings.heading -%}
    {%- endif -%}

    <h1 class="cn-page-title">{{ section.settings.heading }}</h1>
    {%- if section.settings.subheading != blank -%}
      <p class="cn-page-subtitle">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="cn-storelocator-grid">
        {%- for block in section.blocks -%}
          <article class="cn-storelocator-card" {{ block.shopify_attributes }}>
            {%- if block.settings.tag != blank -%}
              <span class="cn-storelocator-tag">{{ block.settings.tag }}</span>
            {%- endif -%}
            <h2 class="cn-storelocator-name">{{ block.settings.name }}</h2>
            {%- if block.settings.address != blank -%}
              <p class="cn-storelocator-address">{{ block.settings.address | newline_to_br }}</p>
            {%- endif -%}
            {%- if block.settings.hours != blank -%}
              <p class="cn-storelocator-line"><strong>Hours:</strong> {{ block.settings.hours }}</p>
            {%- endif -%}
            {%- if block.settings.phone != blank -%}
              <p class="cn-storelocator-line"><strong>Phone:</strong> <a href="tel:{{ block.settings.phone | remove: '(' | remove: ')' | remove: '-' | remove: ' ' }}">{{ block.settings.phone }}</a></p>
            {%- endif -%}
            {%- if block.settings.map_link != blank -%}
              <a class="cn-storelocator-directions" href="{{ block.settings.map_link }}" target="_blank" rel="noopener">Get directions →</a>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="cn-storelocator-empty">{{ section.settings.empty_text }}</div>
    {%- endif -%}

    {%- if section.settings.footer_text != blank -%}
      <div class="cn-storelocator-footer">{{ section.settings.footer_text }}</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "CN store locator",
  "settings": [
    { "type": "checkbox", "id": "show_breadcrumbs", "label": "Show breadcrumbs", "default": true },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find a Store" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "College Nation is online-first, but you can find us at these retail partners and campus pop-ups." },
    { "type": "textarea", "id": "empty_text", "label": "Empty state text", "default": "We're online-first for now. Follow us on social to hear about campus pop-ups near you!" },
    { "type": "richtext", "id": "footer_text", "label": "Footer note", "default": "<p>Want us at your campus? <a href=\"/pages/contact\">Get in touch</a> about a pop-up.</p>" },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 72 }
  ],
  "blocks": [
    {
      "type": "store",
      "name": "Store / location",
      "settings": [
        { "type": "text", "id": "tag", "label": "Tag", "default": "Retail Partner" },
        { "type": "text", "id": "name", "label": "Name", "default": "Campus Bookstore" },
        { "type": "textarea", "id": "address", "label": "Address", "default": "123 University Ave\nTuscaloosa, AL 35401" },
        { "type": "text", "id": "hours", "label": "Hours", "default": "Mon-Sat 9am-8pm" },
        { "type": "text", "id": "phone", "label": "Phone" },
        { "type": "url", "id": "map_link", "label": "Directions link (Google Maps)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "CN store locator",
      "blocks": [
        { "type": "store", "settings": { "tag": "Retail Partner", "name": "Alabama Campus Bookstore", "address": "123 University Ave\nTuscaloosa, AL 35401", "hours": "Mon-Sat 9am-8pm" } },
        { "type": "store", "settings": { "tag": "Pop-Up", "name": "Michigan Game Day Tent", "address": "Central Campus\nAnn Arbor, MI 48109", "hours": "Home game weekends" } }
      ]
    }
  ]
}
{% endschema %}
