{{ 'college-nation-home.css' | asset_url | stylesheet_tag }}

<section class="cn-home cn-promo-tiles" style="--cn-padding-top: {{ section.settings.padding_top }}px; --cn-padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="cn-home-container">
    <div class="cn-promo-grid">
      {%- for block in section.blocks -%}
        {%- assign tile_link = block.settings.link | default: routes.all_products_collection_url -%}
        <a class="cn-promo-tile" href="{{ tile_link }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1200 | image_tag: class: 'cn-promo-img', loading: 'lazy', sizes: '(max-width: 768px) 100vw, 50vw', widths: '500, 800, 1200', alt: block.settings.heading }}
          {%- elsif block.settings.fallback_image_url != blank -%}
            <img class="cn-promo-img" src="{{ block.settings.fallback_image_url }}" alt="{{ block.settings.heading | escape }}" width="1000" height="667" loading="lazy">
          {%- endif -%}
          <div class="cn-promo-content">
            <h2 class="cn-promo-title">{{ block.settings.heading | newline_to_br }}</h2>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CN promo tiles",
  "settings": [
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 8 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 72 }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        { "type": "textarea", "id": "heading", "label": "Heading", "default": "BEST\nSELLERS" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "fallback_image_url", "label": "Fallback image URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "CN promo tiles",
      "blocks": [
        { "type": "tile", "settings": { "heading": "BEST\nSELLERS", "fallback_image_url": "https://images.unsplash.com/photo-1620799140408-edc6dcb6d633?auto=format&fit=crop&w=1000&q=80" } },
        { "type": "tile", "settings": { "heading": "WINNING\nOUTERWEAR", "fallback_image_url": "https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=crop&w=1000&q=80" } }
      ]
    }
  ]
}
{% endschema %}
