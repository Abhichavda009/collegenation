{{ 'college-nation-home.css' | asset_url | stylesheet_tag }}

<section class="cn-home cn-sbc" data-cn-sbc style="--cn-padding-top: {{ section.settings.padding_top }}px; --cn-padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="cn-home-container">
    <div class="cn-sbc-inner">
      <div class="cn-sbc-left">
        <span class="cn-sbc-eyebrow">{{ section.settings.eyebrow }}</span>
        <div class="cn-sbc-tabs" role="tablist">
          {%- for block in section.blocks -%}
            <button class="cn-sbc-tab{% if forloop.first %} is-active{% endif %}" type="button" data-cn-sbc-tab="{{ block.id }}" {{ block.shopify_attributes }}>
              {{ block.settings.label }}
            </button>
          {%- endfor -%}
        </div>
        {%- for block in section.blocks -%}
          <div data-cn-sbc-panel="{{ block.id }}" {% unless forloop.first %}hidden{% endunless %}>
            <div class="cn-sbc-thumbs">
              {%- assign thumbs = block.settings.thumb_urls | split: ',' -%}
              {%- for thumb in thumbs limit: 4 -%}
                {%- assign clean_thumb = thumb | strip -%}
                {%- if clean_thumb != blank -%}
                  <img class="cn-sbc-thumb" src="{{ clean_thumb }}" alt="" width="200" height="200" loading="lazy">
                {%- endif -%}
              {%- endfor -%}
            </div>
            <div class="cn-sbc-desc">{{ block.settings.description }}</div>
            <a class="cn-sbc-btn" href="{{ block.settings.link | default: routes.all_products_collection_url }}">{{ block.settings.button_label }}</a>
          </div>
        {%- endfor -%}
      </div>
      <div>
        {%- for block in section.blocks -%}
          <a class="cn-sbc-media" href="{{ block.settings.link | default: routes.all_products_collection_url }}" data-cn-sbc-panel="{{ block.id }}" {% unless forloop.first %}hidden{% endunless %}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(max-width: 900px) 100vw, 50vw', widths: '600, 900, 1200', alt: block.settings.label }}
            {%- elsif block.settings.fallback_image_url != blank -%}
              <img src="{{ block.settings.fallback_image_url }}" alt="{{ block.settings.label | escape }}" width="1100" height="734" loading="lazy">
            {%- endif -%}
            <span class="cn-sbc-overlay">
              <span class="cn-sbc-overlay-title">{{ block.settings.overlay_title }}</span>
              <span class="cn-sbc-overlay-script">{{ block.settings.overlay_script }}</span>
            </span>
          </a>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<script src="{{ 'college-nation-home.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "CN shop by collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop By Collection" },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "collection_tab",
      "name": "Collection tab",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Men's" },
        { "type": "text", "id": "overlay_title", "label": "Overlay title", "default": "MEN'S" },
        { "type": "text", "id": "overlay_script", "label": "Overlay script", "default": "Collection" },
        { "type": "richtext", "id": "description", "label": "Description", "default": "<p>Find your <strong>fit</strong> by <strong>Collections</strong> that match your campus life.</p>" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop Now" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "fallback_image_url", "label": "Fallback image URL" },
        { "type": "textarea", "id": "thumb_urls", "label": "Thumbnail URLs, comma separated", "default": "https://images.unsplash.com/photo-1620799140408-edc6dcb6d633?auto=format&fit=crop&w=200&q=80,https://images.unsplash.com/photo-1503342217505-b0a15ec3261c?auto=format&fit=crop&w=200&q=80,https://images.unsplash.com/photo-1556905055-8f358a7a47b2?auto=format&fit=crop&w=200&q=80,https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=crop&w=200&q=80" }
      ]
    }
  ],
  "presets": [
    {
      "name": "CN shop by collection",
      "blocks": [
        { "type": "collection_tab", "settings": { "label": "Men's", "overlay_title": "MEN'S", "fallback_image_url": "https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?auto=format&fit=crop&w=1100&q=80" } },
        { "type": "collection_tab", "settings": { "label": "Women's", "overlay_title": "WOMEN'S", "fallback_image_url": "https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=crop&w=1100&q=80" } },
        { "type": "collection_tab", "settings": { "label": "Kids", "overlay_title": "KIDS", "fallback_image_url": "https://images.unsplash.com/photo-1503342217505-b0a15ec3261c?auto=format&fit=crop&w=1100&q=80" } }
      ]
    }
  ]
}
{% endschema %}
