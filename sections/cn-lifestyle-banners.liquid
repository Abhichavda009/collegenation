{{ 'college-nation-home.css' | asset_url | stylesheet_tag }}

<section class="cn-home cn-lifestyle" style="--cn-padding-top: {{ section.settings.padding_top }}px; --cn-padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="cn-home-container">
    <div class="cn-lifestyle-grid">
      {%- for block in section.blocks -%}
        <a class="cn-lifestyle-banner" href="{{ block.settings.link | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
          <div class="cn-lifestyle-copy">
            <h2 class="cn-lifestyle-title">
              <span class="cn-lifestyle-line">{{ block.settings.heading_line_1 }}</span>
              <span class="cn-lifestyle-line">{{ block.settings.heading_line_2 }} <span class="cn-lifestyle-script">{{ block.settings.script_word }}</span></span>
            </h2>
            <p class="cn-lifestyle-desc">{{ block.settings.text }}</p>
          </div>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 900 | image_tag: class: 'cn-lifestyle-img', loading: 'lazy', sizes: '(max-width: 900px) 50vw, 25vw', widths: '360, 640, 900', alt: block.settings.heading_line_1 }}
          {%- elsif block.settings.fallback_image_url != blank -%}
            <img class="cn-lifestyle-img" src="{{ block.settings.fallback_image_url }}" alt="{{ block.settings.heading_line_1 | escape }}" width="900" height="1200" loading="lazy">
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CN lifestyle banners",
  "settings": [
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 8 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        { "type": "text", "id": "heading_line_1", "label": "Heading line 1", "default": "TOP OFF" },
        { "type": "text", "id": "heading_line_2", "label": "Heading line 2", "default": "YOUR" },
        { "type": "text", "id": "script_word", "label": "Script word", "default": "Look" },
        { "type": "text", "id": "text", "label": "Text", "default": "Cool, comfy hats that elevate your fitness game." },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "fallback_image_url", "label": "Fallback image URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "CN lifestyle banners",
      "blocks": [
        { "type": "banner", "settings": { "heading_line_1": "TOP OFF", "heading_line_2": "YOUR", "script_word": "Look", "text": "Cool, comfy hats that elevate your fitness game.", "fallback_image_url": "https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?auto=format&fit=crop&w=900&q=80" } },
        { "type": "banner", "settings": { "heading_line_1": "SHOP", "heading_line_2": "", "script_word": "Gifts", "text": "Give the gift that reps their roots.", "fallback_image_url": "https://images.unsplash.com/photo-1556905055-8f358a7a47b2?auto=format&fit=crop&w=900&q=80" } }
      ]
    }
  ]
}
{% endschema %}
