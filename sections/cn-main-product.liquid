{{ 'college-nation-commerce.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign stock_qty = current_variant.inventory_quantity | at_least: 0
  assign stock_pct = stock_qty | at_most: 10 | times: 10
  if stock_pct < 10 and current_variant.available
    assign stock_pct = 10
  endif
-%}

<script type="application/ld+json">
  {{ product | structured_data }}
</script>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": {{ shop.url | append: routes.root_url | json }}
      }
      {%- if collection -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ collection.title | json }},
          "item": {{ shop.url | append: collection.url | json }}
        }
      {%- endif -%}
      ,{
        "@type": "ListItem",
        "position": {%- if collection -%}3{%- else -%}2{%- endif -%},
        "name": {{ product.title | json }},
        "item": {{ shop.url | append: product.url | json }}
      }
    ]
  }
</script>

<section class="cn-commerce" data-cn-product>
  <div class="cn-product-inner">
    <nav class="cn-commerce-crumbs" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      {%- if collection -%}
        <span class="cn-commerce-sep" aria-hidden="true">|</span>
        <a href="{{ collection.url }}">Collection: {{ collection.title }}</a>
      {%- endif -%}
      <span class="cn-commerce-sep" aria-hidden="true">|</span>
      <span class="cn-commerce-crumb-active">{{ product.title }}</span>
    </nav>

    <div class="cn-product-body">
      <div class="cn-product-gallery">
        <div class="cn-product-media">
          {%- if product.featured_media -%}
            {%- assign main_image = product.featured_media.preview_image -%}
            <img
              src="{{ main_image | image_url: width: 1200 }}"
              srcset="{{ main_image | image_url: width: 600 }} 600w, {{ main_image | image_url: width: 900 }} 900w, {{ main_image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 860px) 100vw, 50vw"
              alt="{{ product.title | escape }}"
              width="{{ main_image.width }}"
              height="{{ main_image.height }}"
              loading="eager"
              fetchpriority="high"
              data-cn-main-image
            >
          {%- endif -%}
        </div>
        {%- if product.media.size > 1 -%}
          <div class="cn-product-thumbs">
            {%- for media in product.media -%}
              {%- if media.preview_image -%}
                {%- assign thumb_src = media.preview_image | image_url: width: 1200 -%}
                {%- capture thumb_srcset -%}
                  {{ media.preview_image | image_url: width: 600 }} 600w, {{ media.preview_image | image_url: width: 900 }} 900w, {{ media.preview_image | image_url: width: 1200 }} 1200w
                {%- endcapture -%}
                <button
                  class="cn-product-thumb{% if forloop.first %} is-active{% endif %}"
                  type="button"
                  data-cn-thumb
                  data-cn-image-src="{{ thumb_src }}"
                  data-cn-image-srcset="{{ thumb_srcset | strip }}"
                  aria-label="View image {{ forloop.index }}"
                >
                  {{ media.preview_image | image_url: width: 160 | image_tag: loading: 'lazy', sizes: '72px', widths: '100, 160', alt: product.title }}
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="cn-product-info">
        <h1 class="cn-product-title">{{ product.title }}</h1>
        <div class="cn-product-meta">
          {%- if product.vendor != blank -%}
            <span>Vendor: <a href="{{ routes.search_url }}?q={{ product.vendor | url_encode }}">{{ product.vendor }}</a></span>
          {%- endif -%}
          {%- if current_variant.sku != blank -%}
            <span class="cn-commerce-sep" aria-hidden="true">|</span>
            <span>SKU: <span data-cn-sku>{{ current_variant.sku }}</span></span>
          {%- endif -%}
        </div>

        <div class="cn-product-price" data-cn-product-price>{{ current_variant.price | money }}</div>

        {%- if current_variant.available -%}
          <p class="cn-product-stock">Hurry up, only <strong>{{ stock_qty }}</strong> items left in stock.</p>
          <div class="cn-product-bar"><span style="width: {{ stock_pct }}%;"></span></div>
        {%- else -%}
          <p class="cn-product-stock is-out">Out of stock</p>
        {%- endif -%}

        {%- form 'product', product, class: 'cn-product-form' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-cn-variant-select>

          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div class="cn-product-option">
                <span class="cn-product-option-label">
                  {{ option.name }}:
                  <span>{{ option.selected_value }}</span>
                </span>
                <div class="cn-product-values">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="cn-product-value{% if option.selected_value == value %} is-active{% endif %}"
                      data-cn-option-position="{{ option.position }}"
                      data-cn-option-value="{{ value | escape }}"
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endunless -%}

          <div class="cn-product-actions">
            <div class="cn-product-qty">
              <button type="button" aria-label="Decrease quantity" data-cn-qty-minus>-</button>
              <input type="number" name="quantity" min="1" value="1" data-cn-quantity aria-label="Quantity">
              <button type="button" aria-label="Increase quantity" data-cn-qty-plus>+</button>
            </div>
            <button
              type="submit"
              class="cn-product-add"
              data-cn-add-button
              data-available-text="{{ section.settings.add_to_cart_label }}"
              data-sold-out-text="{{ section.settings.sold_out_label }}"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              {%- if current_variant.available -%}{{ section.settings.add_to_cart_label }}{%- else -%}{{ section.settings.sold_out_label }}{%- endif -%}
            </button>
          </div>

          {%- if section.settings.show_dynamic_checkout -%}
            <div class="cn-product-dynamic">{{ form | payment_button }}</div>
          {%- endif -%}
        {%- endform -%}

        <div class="cn-product-description">
          {{ product.description }}
          {%- if product.metafields.custom.specifications != blank -%}
            <h2>{{ section.settings.specifications_heading }}</h2>
            {{ product.metafields.custom.specifications | metafield_tag }}
          {%- endif -%}
        </div>

        <div class="cn-product-extra">
          <a href="#share">Share</a>
          <a href="{{ section.settings.shipping_link | default: '#' }}">{{ section.settings.shipping_label }}</a>
        </div>
      </div>
    </div>
  </div>

  <script type="application/json" data-cn-variants-json>
    [
      {%- for variant in product.variants -%}
        {
          "id": {{ variant.id | json }},
          "available": {{ variant.available | json }},
          "options": {{ variant.options | json }},
          "priceFormatted": {{ variant.price | money | json }},
          "sku": {{ variant.sku | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  </script>
</section>

<script src="{{ 'college-nation-commerce.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "CN main product",
  "settings": [
    { "type": "text", "id": "add_to_cart_label", "label": "Add to cart label", "default": "Add To Cart" },
    { "type": "text", "id": "sold_out_label", "label": "Sold out label", "default": "Sold Out" },
    { "type": "checkbox", "id": "show_dynamic_checkout", "label": "Show dynamic checkout", "default": true },
    { "type": "text", "id": "shipping_label", "label": "Shipping link label", "default": "Shipping Details" },
    { "type": "url", "id": "shipping_link", "label": "Shipping link" },
    { "type": "text", "id": "specifications_heading", "label": "Specifications heading", "default": "Specifications" }
  ],
  "presets": [{ "name": "CN main product" }]
}
{% endschema %}
