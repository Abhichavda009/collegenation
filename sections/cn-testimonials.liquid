{{ 'college-nation-home.css' | asset_url | stylesheet_tag }}

<section class="cn-home cn-reviews" style="--cn-padding-top: {{ section.settings.padding_top }}px; --cn-padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="cn-home-container">
    {%- if section.settings.eyebrow != blank -%}
      <span class="cn-reviews-eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h2 class="cn-home-section-title">{{ section.settings.heading }}</h2>
    <div class="cn-reviews-grid">
      {%- for block in section.blocks -%}
        <article class="cn-reviews-card" {{ block.shopify_attributes }}>
          <div class="cn-reviews-stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {%- assign rating = block.settings.rating | at_most: 5 | at_least: 0 -%}
            {%- for i in (1..5) -%}
              <span class="cn-reviews-star{% if i <= rating %} is-on{% endif %}" aria-hidden="true">★</span>
            {%- endfor -%}
          </div>
          <p class="cn-reviews-quote">{{ block.settings.quote }}</p>
          <div class="cn-reviews-author">
            <span class="cn-reviews-avatar" aria-hidden="true">{{ block.settings.author | slice: 0 }}</span>
            <span class="cn-reviews-meta">
              <strong>{{ block.settings.author }}</strong>
              <span>{{ block.settings.detail }}</span>
            </span>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CN testimonials",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Reviews" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved On Campus" },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 8 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "rating", "label": "Star rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "The hoodie quality is unreal and it shipped fast. Reppin' my school everywhere now!" },
        { "type": "text", "id": "author", "label": "Author", "default": "Jordan M." },
        { "type": "text", "id": "detail", "label": "Detail", "default": "Alabama '26" }
      ]
    }
  ],
  "presets": [
    {
      "name": "CN testimonials",
      "blocks": [
        { "type": "review", "settings": { "rating": 5, "quote": "The hoodie quality is unreal and it shipped fast. Reppin' my school everywhere now!", "author": "Jordan M.", "detail": "Alabama '26" } },
        { "type": "review", "settings": { "rating": 5, "quote": "Officially licensed gear at a fair price. Got my whole crew matching for game day.", "author": "Priya S.", "detail": "Michigan '25" } },
        { "type": "review", "settings": { "rating": 4, "quote": "Great fit and true to size. Ordered a gift for my little sister and she loves it.", "author": "Chris T.", "detail": "Kansas '27" } }
      ]
    }
  ]
}
{% endschema %}
