{{ 'college-nation-customer.css' | asset_url | stylesheet_tag }}

<section class="cn-customer">
  <div class="cn-customer__shell">
    <a class="cn-customer__logo" href="{{ routes.root_url }}">COLLEGE NATION</a>

    <div class="cn-customer__card">
      <h1>{{ section.settings.heading }}</h1>
      <p class="cn-customer__sub">{{ section.settings.subheading }}</p>

      {%- form 'create_customer', class: 'cn-customer__form' -%}
        {%- if form.errors -%}
          <div class="cn-customer__errors">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        <label class="cn-customer__field">
          <span>First name</span>
          <input type="text" name="customer[first_name]" autocomplete="given-name">
        </label>
        <label class="cn-customer__field">
          <span>Last name</span>
          <input type="text" name="customer[last_name]" autocomplete="family-name">
        </label>
        <label class="cn-customer__field">
          <span>Email</span>
          <input type="email" name="customer[email]" autocomplete="email" required>
        </label>
        <label class="cn-customer__field">
          <span>Password</span>
          <input type="password" name="customer[password]" autocomplete="new-password" required>
        </label>

        <button class="cn-customer__button" type="submit">{{ section.settings.button_label }}</button>
      {%- endform -%}

      <div class="cn-customer__links">
        <a href="{{ routes.account_login_url }}">Already have an account?</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CollegeNation register",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Create account" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Save your details and view order history." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Create account" }
  ]
}
{% endschema %}
