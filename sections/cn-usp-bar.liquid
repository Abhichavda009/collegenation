{{ 'college-nation-home.css' | asset_url | stylesheet_tag }}

<section class="cn-home cn-usp" style="--cn-padding-top: {{ section.settings.padding_top }}px; --cn-padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="cn-home-container">
    <div class="cn-usp-row">
      {%- for block in section.blocks -%}
        <div class="cn-usp-item" {{ block.shopify_attributes }}>
          <span class="cn-usp-icon" aria-hidden="true">{{ block.settings.icon }}</span>
          <span class="cn-usp-text">
            <strong>{{ block.settings.title }}</strong>
            <span>{{ block.settings.subtitle }}</span>
          </span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CN USP bar",
  "settings": [
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 24 }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji or short text)", "default": "✓" },
        { "type": "text", "id": "title", "label": "Title", "default": "Free Shipping" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "On orders over ₹45" }
      ]
    }
  ],
  "presets": [
    {
      "name": "CN USP bar",
      "blocks": [
        { "type": "feature", "settings": { "icon": "🚚", "title": "Free Shipping", "subtitle": "On orders over ₹45" } },
        { "type": "feature", "settings": { "icon": "🎓", "title": "Officially Licensed", "subtitle": "Authentic campus gear" } },
        { "type": "feature", "settings": { "icon": "↺", "title": "Easy Returns", "subtitle": "30-day hassle free" } },
        { "type": "feature", "settings": { "icon": "🔒", "title": "Secure Checkout", "subtitle": "Protected payments" } }
      ]
    }
  ]
}
{% endschema %}
