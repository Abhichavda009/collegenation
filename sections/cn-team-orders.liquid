{{ 'college-nation-pages.css' | asset_url | stylesheet_tag }}

<section class="cn-page">
  <div class="cn-page-container" style="--cn-page-padding-top: {{ section.settings.padding_top }}px; --cn-page-padding-bottom: {{ section.settings.padding_bottom }}px;">
    {%- if section.settings.show_breadcrumbs -%}
      {%- render 'cn-breadcrumb', title: section.settings.heading -%}
    {%- endif -%}

    <h1 class="cn-page-title">{{ section.settings.heading }}</h1>
    {%- if section.settings.subheading != blank -%}
      <p class="cn-page-subtitle">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="cn-team-perks">
        {%- for block in section.blocks -%}
          <div class="cn-team-perk" {{ block.shopify_attributes }}>
            <span class="cn-team-perk-icon" aria-hidden="true">{{ block.settings.icon }}</span>
            <strong>{{ block.settings.title }}</strong>
            <span>{{ block.settings.text }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="cn-team-form-wrap">
      <h2 class="cn-team-form-title">{{ section.settings.form_heading }}</h2>
      {%- form 'contact', class: 'cn-contact-form' -%}
        {%- if form.posted_successfully? -%}
          <p class="cn-contact-message cn-contact-message-success" role="status">{{ section.settings.success_message }}</p>
        {%- elsif form.errors -%}
          <div class="cn-contact-message cn-contact-message-error" role="alert">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        <input type="hidden" name="contact[subject]" value="Team / Group Order Request">
        <div class="cn-contact-grid">
          <div class="cn-contact-field">
            <label for="TeamName-{{ section.id }}">Your name</label>
            <input id="TeamName-{{ section.id }}" type="text" name="contact[name]" value="{% if form.name %}{{ form.name }}{% endif %}">
          </div>
          <div class="cn-contact-field">
            <label for="TeamEmail-{{ section.id }}">Email <span class="cn-contact-required">*</span></label>
            <input id="TeamEmail-{{ section.id }}" type="email" name="contact[email]" value="{% if form.email %}{{ form.email }}{% endif %}" required autocomplete="email">
          </div>
          <div class="cn-contact-field">
            <label for="TeamOrg-{{ section.id }}">Organization / team</label>
            <input id="TeamOrg-{{ section.id }}" type="text" name="contact[Organization]" placeholder="Club, team, Greek chapter, dorm...">
          </div>
          <div class="cn-contact-field">
            <label for="TeamUni-{{ section.id }}">University</label>
            <input id="TeamUni-{{ section.id }}" type="text" name="contact[University]">
          </div>
          <div class="cn-contact-field">
            <label for="TeamQty-{{ section.id }}">Estimated quantity</label>
            <input id="TeamQty-{{ section.id }}" type="number" min="1" name="contact[Estimated quantity]" placeholder="e.g. 25">
          </div>
          <div class="cn-contact-field">
            <label for="TeamPhone-{{ section.id }}">Phone</label>
            <input id="TeamPhone-{{ section.id }}" type="tel" name="contact[phone]" autocomplete="tel">
          </div>
          <div class="cn-contact-field cn-contact-field-full">
            <label for="TeamMsg-{{ section.id }}">Tell us about your order</label>
            <textarea id="TeamMsg-{{ section.id }}" name="contact[body]" rows="6" placeholder="Products, colors, custom designs, deadline...">{% if form.body %}{{ form.body }}{% endif %}</textarea>
          </div>
        </div>
        <button type="submit" class="cn-contact-submit">{{ section.settings.button_label }}</button>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CN team orders",
  "settings": [
    { "type": "checkbox", "id": "show_breadcrumbs", "label": "Show breadcrumbs", "default": true },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Team & Group Orders" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Outfitting a club, team, Greek chapter, or dorm? Get bulk pricing and custom options. Tell us what you need and our team will send a quote." },
    { "type": "text", "id": "form_heading", "label": "Form heading", "default": "Request a quote" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Request a Quote" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thanks! Your request has been sent. Our team will reach out with a quote shortly." },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 72 }
  ],
  "blocks": [
    {
      "type": "perk",
      "name": "Perk",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "💸" },
        { "type": "text", "id": "title", "label": "Title", "default": "Bulk Pricing" },
        { "type": "text", "id": "text", "label": "Text", "default": "The more you order, the more you save." }
      ]
    }
  ],
  "presets": [
    {
      "name": "CN team orders",
      "blocks": [
        { "type": "perk", "settings": { "icon": "💸", "title": "Bulk Pricing", "text": "The more you order, the more you save." } },
        { "type": "perk", "settings": { "icon": "🎨", "title": "Custom Designs", "text": "Add names, numbers, and chapter logos." } },
        { "type": "perk", "settings": { "icon": "🧑‍💼", "title": "Dedicated Rep", "text": "One point of contact from quote to delivery." } },
        { "type": "perk", "settings": { "icon": "⚡", "title": "Fast Turnaround", "text": "On time for game day or rush week." } }
      ]
    }
  ]
}
{% endschema %}
