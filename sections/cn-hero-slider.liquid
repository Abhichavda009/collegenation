{{ 'college-nation-home.css' | asset_url | stylesheet_tag }}

<section class="cn-home cn-hero" data-cn-hero style="--cn-padding-top: {{ section.settings.padding_top }}px; --cn-padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="cn-home-container">
    <div class="cn-hero-viewport" aria-roledescription="carousel">
      <div class="cn-hero-track" data-cn-hero-track>
        {%- for block in section.blocks -%}
          {%- assign slide_link = block.settings.link | default: routes.all_products_collection_url -%}
          {%- assign fallback_image = block.settings.fallback_image_url -%}
          <a class="cn-hero-slide" href="{{ slide_link }}" style="--cn-panel: {{ block.settings.panel_color }};" data-cn-hero-slide {{ block.shopify_attributes }}>
            <div class="cn-hero-copy">
              {%- if block.settings.badge != blank -%}
                <span class="cn-hero-badge">{{ block.settings.badge }}</span>
              {%- endif -%}
              <h2 class="cn-hero-title">{{ block.settings.heading }}</h2>
              <div class="cn-hero-text">{{ block.settings.text }}</div>
              {%- if block.settings.button_label != blank -%}
                <span class="cn-hero-cta">{{ block.settings.button_label }}</span>
              {%- endif -%}
            </div>
            <div class="cn-hero-media">
              {%- if block.settings.image != blank -%}
                {%- if forloop.first -%}
                  {{ block.settings.image | image_url: width: 1400 | image_tag: loading: 'eager', fetchpriority: 'high', sizes: '(max-width: 900px) 100vw, 54vw', widths: '500, 800, 1100, 1400', alt: block.settings.heading }}
                {%- else -%}
                  {{ block.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', sizes: '(max-width: 900px) 100vw, 54vw', widths: '500, 800, 1100, 1400', alt: block.settings.heading }}
                {%- endif -%}
              {%- elsif fallback_image != blank -%}
                <img src="{{ fallback_image }}" alt="{{ block.settings.heading | escape }}" width="1100" height="734" {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}>
              {%- endif -%}
            </div>
          </a>
        {%- endfor -%}
      </div>
      {%- if section.blocks.size > 1 -%}
        <div class="cn-hero-controls">
          <button class="cn-hero-arrow" type="button" aria-label="Previous slide" data-cn-hero-prev>&#8249;</button>
          <div class="cn-hero-dots">
            {%- for block in section.blocks -%}
              <button class="cn-hero-dot{% if forloop.first %} is-active{% endif %}" type="button" aria-label="Go to slide {{ forloop.index }}" data-cn-hero-dot></button>
            {%- endfor -%}
          </div>
          <button class="cn-hero-arrow" type="button" aria-label="Next slide" data-cn-hero-next>&#8250;</button>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<script src="{{ 'college-nation-home.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "CN hero slider",
  "settings": [
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 20 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 8 }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "text", "id": "badge", "label": "Badge", "default": "Drop Alert" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "DROP ALERT" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Fresh Michigan and Villanova styles from Pro Standard and Johnnie-O.</p>" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop the Drop" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "fallback_image_url", "label": "Fallback image URL" },
        { "type": "color", "id": "panel_color", "label": "Panel color", "default": "#0d2343" }
      ]
    }
  ],
  "presets": [
    {
      "name": "CN hero slider",
      "blocks": [
        { "type": "slide", "settings": { "badge": "Drop Alert", "heading": "DROP ALERT", "text": "<p>Fresh Michigan and Villanova styles from Pro Standard and Johnnie-O.</p>", "button_label": "Shop the Drop", "fallback_image_url": "https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?auto=format&fit=crop&w=1100&q=80", "panel_color": "#0d2343" } },
        { "type": "slide", "settings": { "badge": "Just In", "heading": "NEW ARRIVALS", "text": "<p>Gear up for the season with the latest officially licensed campus styles.</p>", "button_label": "Shop New", "fallback_image_url": "https://images.unsplash.com/photo-1556905055-8f358a7a47b2?auto=format&fit=crop&w=1100&q=80", "panel_color": "#6d1f2b" } }
      ]
    }
  ]
}
{% endschema %}
