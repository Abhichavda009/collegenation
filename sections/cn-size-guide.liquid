{{ 'college-nation-pages.css' | asset_url | stylesheet_tag }}

<section class="cn-page">
  <div class="cn-page-container" style="--cn-page-padding-top: {{ section.settings.padding_top }}px; --cn-page-padding-bottom: {{ section.settings.padding_bottom }}px;">
    {%- if section.settings.show_breadcrumbs -%}
      {%- render 'cn-breadcrumb', title: section.settings.heading -%}
    {%- endif -%}

    <h1 class="cn-page-title">{{ section.settings.heading }}</h1>
    {%- if section.settings.subheading != blank -%}
      <p class="cn-page-subtitle">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.measure_text != blank -%}
      <div class="cn-sizeguide-measure">{{ section.settings.measure_text }}</div>
    {%- endif -%}

    <div class="cn-sizeguide-charts">
      {%- for block in section.blocks -%}
        <div class="cn-sizeguide-chart" {{ block.shopify_attributes }}>
          <h2 class="cn-sizeguide-chart-title">{{ block.settings.title }}</h2>
          {%- assign rows = block.settings.rows | strip | newline_to_br | split: '<br />' -%}
          <div class="cn-sizeguide-table-wrap">
            <table class="cn-sizeguide-table">
              <thead>
                <tr>
                  {%- assign header_cells = rows[0] | strip | split: '|' -%}
                  {%- for cell in header_cells -%}<th>{{ cell | strip }}</th>{%- endfor -%}
                </tr>
              </thead>
              <tbody>
                {%- for row in rows offset: 1 -%}
                  {%- assign row_clean = row | strip -%}
                  {%- if row_clean != blank -%}
                    <tr>
                      {%- assign cells = row_clean | split: '|' -%}
                      {%- for cell in cells -%}<td>{{ cell | strip }}</td>{%- endfor -%}
                    </tr>
                  {%- endif -%}
                {%- endfor -%}
              </tbody>
            </table>
          </div>
          {%- if block.settings.note != blank -%}
            <p class="cn-sizeguide-note">{{ block.settings.note }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CN size guide",
  "settings": [
    { "type": "checkbox", "id": "show_breadcrumbs", "label": "Show breadcrumbs", "default": true },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Size Guide" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Find your perfect fit. All measurements are in inches. If you're between sizes, we recommend sizing up." },
    { "type": "richtext", "id": "measure_text", "label": "How to measure", "default": "<p><strong>How to measure:</strong> Use a soft tape measure. For chest/bust, measure around the fullest part. For length, measure from the top of the shoulder to the hem.</p>" },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 72 }
  ],
  "blocks": [
    {
      "type": "chart",
      "name": "Size chart",
      "settings": [
        { "type": "text", "id": "title", "label": "Chart title", "default": "Men's Tops" },
        { "type": "textarea", "id": "rows", "label": "Rows (first line = headers, cells separated by |)", "default": "Size | Chest (in) | Length (in)\nS | 34-36 | 28\nM | 38-40 | 29\nL | 42-44 | 30\nXL | 46-48 | 31\n2XL | 50-52 | 32" },
        { "type": "text", "id": "note", "label": "Note" }
      ]
    }
  ],
  "presets": [
    {
      "name": "CN size guide",
      "blocks": [
        { "type": "chart", "settings": { "title": "Men's Tops", "rows": "Size | Chest (in) | Length (in)\nS | 34-36 | 28\nM | 38-40 | 29\nL | 42-44 | 30\nXL | 46-48 | 31\n2XL | 50-52 | 32" } },
        { "type": "chart", "settings": { "title": "Women's Tops", "rows": "Size | Bust (in) | Waist (in)\nXS | 31-32 | 24-25\nS | 33-34 | 26-27\nM | 35-36 | 28-29\nL | 38-40 | 31-33\nXL | 42-44 | 35-37" } },
        { "type": "chart", "settings": { "title": "Kids", "rows": "Size | Age | Height (in)\nXS | 4-5 | 40-45\nS | 6-7 | 46-50\nM | 8-10 | 51-55\nL | 12-14 | 56-61" } }
      ]
    }
  ]
}
{% endschema %}
